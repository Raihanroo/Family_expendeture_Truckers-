{
  "version": 2,
  "builds": [
    {
      "src": "core/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/API_Documentation.html",
      "dest": "/static/API_Documentation.html"
    },
    {
      "src": "/api/docs",
      "dest": "/static/API_Documentation.html"
    },
    {
      "src": "/static/admin/(.*)",
      "dest": "/static/admin/$1"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/staticfiles/(.*)",
      "dest": "/staticfiles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "core/wsgi.py"
    }
  ],
  "env": {
    "DJANGO_SETTINGS_MODULE": "core.settings",
    "SECRET_KEY": "@vercel_secret_key",
    "DEBUG": "True",
    "ALLOWED_HOSTS": "*.vercel.app"
  }
}